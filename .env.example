# Copia este archivo a .env.local y completa con tus credenciales de Supabase.
# Project Settings → API en el panel de Supabase.
#
# Si dejas esto vacío, el sitio funciona igual usando los datos de ejemplo
# (src/lib/seed-data.ts). Al completar estas variables, los datos pasan a
# venir de tu base de datos.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
